# Upstash Redis — add via Vercel Dashboard → Integrations → Upstash (free tier).
# Env vars are injected automatically once the integration is linked.
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# RPC endpoints — free public ones work for testnet
BASE_SEPOLIA_RPC=https://sepolia.base.org
ETHEREUM_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
BASE_MAINNET_RPC=https://mainnet.base.org
ETHEREUM_MAINNET_RPC=https://eth.llamarpc.com

# Deployed contracts — Ethereum Sepolia (eip155:11155111), deployed 2026-06-26
PAYMENT_GATE_ADDRESS_ETH_SEPOLIA=0x21E79Eae30E6A8C2a5BeD993aB6352403A31D566
PLATFORM_WALLET_ADDRESS_ETH_SEPOLIA=0xa33561d9E8f9a2297272c0e374CC1B94A50a3691
SECURE_WALLET_ADDRESS_ETH_SEPOLIA=0xE0E8cd76bc8EF5Dd3Ed1B81764fC4b46a774cfcc
PAYROLL_SCHEDULER_ADDRESS_ETH_SEPOLIA=0xeF75A5053a878B26bbB9eD3D5b548148Bc8a82d5

